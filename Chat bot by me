blAddBtn.MouseButton1Click:Connect(function()
    closeBlModal()
    task.delay(.18, function()
        showBlDimmer(true)
        addPopup.BackgroundTransparency = 0
        addPopup.Visible = true
        addPopup.Size = UDim2.fromOffset(250, 34)
        pcall(function()
            Tw(addPopup, .15, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {Size = UDim2.fromOffset(270, 40)})
        end)
        task.delay(2.5, function()
            if addModeActive then
                pcall(function()
                    Tw(addPopup, .35, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {BackgroundTransparency = 1})
                end)
                task.delay(.4, function()
                    if addModeActive then addPopup.Visible = false end
                end)
            end
        end)
        addModeActive = true
        addModeConn = UIS.InputBegan:Connect(function(inp, gpe)
            if gpe or not addModeActive then return end
            if inp.UserInputType ~= Enum.UserInputType.MouseButton1
                and inp.UserInputType ~= Enum.UserInputType.Touch then return end
            local ray = Camera:ScreenPointToRay(inp.Position.X, inp.Position.Y)
            local rp = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances = LP.Character and {LP.Character} or {}
            local result = workspace:Raycast(ray.Origin, ray.Direction * 600, rp)
            if result and result.Instance then
                local found = nil
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LP and p.Character and result.Instance:IsDescendantOf(p.Character) then
                        found = p; break
                    end
                end
                if found then
                    S.blacklist[tostring(found.UserId)] = found.DisplayName
                    saveSettings(); exitAddMode()
                    pcall(function()
                        if StarterGui then
                            StarterGui:SetCore("SendNotification", {
                                Title = "⛔ Blacklisted",
                                Text = found.DisplayName .. " will be ignored.",
                                Duration = 3
                            })
                        end
                    end)
                end
            end
        end)
    end)
end)

