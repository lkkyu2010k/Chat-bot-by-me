-- SAFE INSTANCE CREATOR — ครอบทุก Instance.new และ property set
-- ═══════════════════════════════════════════════════════════════
local function safeNew(cls)
    local ok, inst = pcall(Instance.new, cls)
    return (ok and inst) or nil
end

local function safeProp(inst, prop, val)
    if not inst then return end
    pcall(function() inst[prop] = val end)
end

local function safeCorner(inst, radius)
    if not inst then return end
    pcall(function()
        local c = safeNew("UICorner")
        if c then
            safeProp(c, "CornerRadius", UDim.new(0, radius or 8))
            safeProp(c, "Parent", inst)
        end
    end)
end

local function safeStroke(inst, color, thickness)
    if not inst then return end
    pcall(function()
        local s = safeNew("UIStroke")
        if s then
            safeProp(s, "Color", color or Color3.fromRGB(200, 202, 220))
            safeProp(s, "Thickness", thickness or 1)
            safeProp(s, "Parent", inst)
        end
    end)
    -- Return the stroke so caller can store it
    for _, ch in ipairs(inst:GetChildren()) do
        if ch:IsA("UIStroke") then return ch end
    end
end

