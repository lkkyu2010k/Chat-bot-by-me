-- GLOBAL THEME APPLICATOR
-- ═══════════════════════════════════════════════════════════════
local _ck = function(c) return math.floor(c.R*255+.5)..","..math.floor(c.G*255+.5)..","..math.floor(c.B*255+.5) end
local THEME_TI = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function applyThemeGlobal(themeName)
        local newT = THEMES[themeName] or THEMES.dark
        local oldCmap = {}
        for k, oc in pairs(C) do oldCmap[_ck(oc)] = newT[k] end

        local function walk(inst)
                pcall(function()
                        if inst:IsA("GuiObject") then
                                local m = oldCmap[_ck(inst.BackgroundColor3)]
                                if m then TweenService:Create(inst, THEME_TI, {BackgroundColor3 = m}):Play() end
                        end
                        if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
                                local m = oldCmap[_ck(inst.TextColor3)]
                                if m then TweenService:Create(inst, THEME_TI, {TextColor3 = m}):Play() end
                        end
                        if inst:IsA("UIStroke") then
                                local m = oldCmap[_ck(inst.Color)]
                                if m then TweenService:Create(inst, THEME_TI, {Color = m}):Play() end
                        end
                end)
                for _, ch in ipairs(inst:GetChildren()) do walk(ch) end
        end
        walk(sg)
        applyThemeColors(themeName)
        saveSettings()
end

