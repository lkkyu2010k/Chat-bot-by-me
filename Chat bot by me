local function refreshWhitelist()
        for _, ch in ipairs(wlScroll:GetChildren()) do
                if ch:IsA("Frame") or ch:IsA("TextLabel") then ch:Destroy() end
        end
        local filtered = {}
        for _, name in ipairs(S.whitelist) do
                if searchText == "" or tostring(name):lower():find(searchText:lower(), 1, true) then
                        filtered[#filtered+1] = name
                end
        end
        if #filtered == 0 then
                local e = Instance.new("TextLabel", wlScroll)
                e.Size = UDim2.new(1, 0, 0, 30); e.BackgroundTransparency = 1
                e.Text = #S.whitelist == 0 and "No players whitelisted." or "No matches found."
                e.TextColor3 = C.T2
                e.Font = RF; e.TextSize = 9; e.ZIndex = 15
                e.TextXAlignment = Enum.TextXAlignment.Center
                return
        end
        for idx, name in ipairs(filtered) do
                local row = F(wlScroll, UDim2.new(1, -4, 0, 30), nil, C.CD, 6, 16)
                L(row, tostring(name), UDim2.new(1, -62, 0, 18), UDim2.fromOffset(6, 3), 10, BF, C.T1, Enum.TextXAlignment.Left, 17)
