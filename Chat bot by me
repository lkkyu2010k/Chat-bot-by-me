-- TOKEN DISPLAY UPDATE LOOP
-- ═══════════════════════════════════════════════════════════════
task.spawn(function()
        while true do
                task.wait(1)
                pcall(function()
                        -- Update token label in top bar — prominent display
                        local tokText
                        if S.remainingTokens >= 0 then
                                local remaining = math.max(0, S.tokenResetTime - tick())
                                local tokStr = tostring(S.remainingTokens)
                                -- Simple comma formatting
                                local formatted = ""
                                local len = #tokStr
                                for i = 1, len do
                                        formatted = formatted .. tokStr:sub(i, i)
                                        if (len - i) % 3 == 0 and i < len then formatted = formatted .. "," end
                                end
                                tokText = "⚡ " .. formatted .. " tok"
                                if remaining > 60 then
                                        tokText = tokText .. " | Reset: " .. tostring(math.floor(remaining / 60)) .. "m"
                                elseif remaining > 0 then
                                        tokText = tokText .. " | Reset: " .. tostring(math.floor(remaining)) .. "s"
                                else
                                        tokText = tokText .. " | Reset: --"
                                end
                        else
                                tokText = "⚡ Used: " .. tostring(S.totalTokensUsed) .. " | Reset: --"
                        end
                        tokenLbl.Text = tokText
                        pillToken.Text = S.remainingTokens >= 0 and tostring(S.remainingTokens) or tostring(S.totalTokensUsed)
                end)
        end
end)

