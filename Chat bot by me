            p.Name = "GroqDash"; p.Size = Vector3.new(.7, .08, .08)
            p.Anchored = true; p.CanCollide = false; p.CastShadow = false
            p.Material = Enum.Material.Neon; p.Color = Color3.fromRGB(0, 190, 255)
