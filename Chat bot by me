-- [NEW] Parse Groq reset time strings like "7.66s" or "2m59.56s"
local function parseGroqReset(str)
    if not str or type(str) ~= "string" then return nil end
    local total = 0
    local mins = str:match("(%d+)m")
    local secs = str:match("(%d+%.?%d*)s")
    if mins then total = total + tonumber(mins) * 60 end
    if secs then total = total + tonumber(secs) end
    if total == 0 then
        local n = tonumber(str)
        if n then total = n end
    end
    return total
end

