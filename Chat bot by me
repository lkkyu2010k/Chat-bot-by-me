    end
    if holdPctLbl then
        safeProp(holdPctLbl,"Position",UDim2.fromOffset(mousePos.X-IND_SIZE/2,mousePos.Y+IND_SIZE/2+3))
        safeProp(holdPctLbl,"Text",math.floor(progress*100).."%")
    end
    if progress >= 1 then completeHold() end
end)

