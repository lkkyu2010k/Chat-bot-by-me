-- ═══════════════════════════════════════════════════════════════
local function doConnect(key)
    if type(key) ~= "string" then
        statusLbl.Text = "● Invalid Key"; statusLbl.TextColor3 = C.NO; return
    end
    key = key:gsub("%s+", "")
    if #key < 10 then
        statusLbl.Text = "● Invalid Key"; statusLbl.TextColor3 = C.NO; return
    end
    S.key = key; S.thinking = false; S.nextReq = 0
    statusLbl.Text = "● Connecting..."; statusLbl.TextColor3 = C.WN
    task.spawn(function()
        if fastTest(key) then
            S.connected = true
            statusLbl.Text = "● Connected ✓"; statusLbl.TextColor3 = C.OK
            pillDot.BackgroundColor3 = C.OK
            if writefile then
                pcall(function() writefile(KEY_FILE, key) end)
            end
            makeRing()
        else
            S.connected = false; S.key = ""
            statusLbl.Text = "● Connection Failed"; statusLbl.TextColor3 = C.NO
            pillDot.BackgroundColor3 = C.NO
        end
    end)
end

