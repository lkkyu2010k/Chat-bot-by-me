local function moodLine()
        local t, p = S.traits, {}
        if t.friendly >= 8 then p[#p+1]="super friendly" elseif t.friendly <= 2 then p[#p+1]="cold" end
        if t.funny >= 8 then p[#p+1]="hilarious" elseif t.funny <= 2 then p[#p+1]="serious" end
        if t.quiet >= 8 then p[#p+1]="very quiet" elseif t.quiet <= 2 then p[#p+1]="talkative" end
        if t.smart >= 8 then p[#p+1]="genius" elseif t.smart <= 2 then p[#p+1]="silly" end
        if t.aggro >= 8 then p[#p+1]="aggressive" elseif t.aggro <= 2 then p[#p+1]="kind" end
        return #p > 0 and "Mood: " .. table.concat(p, ", ") .. "." or ""
end

local function buildPersona()
        local p = { CORE_PERSONA }
        local m = moodLine()
        if m ~= "" then p[#p+1] = m end
        if S.userPersona and S.userPersona ~= "" then p[#p+1] = "Extra: " .. S.userPersona end
        return table.concat(p, "\n")
end

local function getCrossMemoryContext(userMsg, currentUid)
        if not userMsg or not currentUid then return nil end
        for uid, name in pairs(S.playerNames) do
                if uid ~= currentUid and userMsg:find(name, 1, true) then
                        local hist = S.playerHistory[uid]
                        if hist and #hist > 0 then
                                local lines = {"[Context about " .. name .. ":]"}
                                local si = math.max(1, #hist - 3)
                                for i = si, #hist do
                                        lines[#lines+1] = (hist[i].role == "user" and name or "You") .. ": " .. hist[i].content
                                end
                                return table.concat(lines, "\n")
                        end
                end
        end
        return nil
end

-- ═══════════════════════════════════════════════════════════════
-- GROQ API CALL — with token tracking from headers
-- ═══════════════════════════════════════════════════════════════
local function callGroq(userMsg, uid, name, isObs, skipSave, isToxic)
        unstick()
        if S.thinking then return nil, "BUSY" end
        if tick() < S.nextReq then return nil, "WAIT" end
        if S.key == "" then return nil, "NOKEY" end
        if not Http or not HttpService then return nil, "NOHTTP" end

        S.thinking = true
        S.thinkStart = tick()

        local uidK = uid and tostring(uid) or nil
        local msgs = {}

        if isObs then
                msgs[#msgs+1] = { role = "system", content = CORE_PERSONA .. "\nObserve what is happening and react casually in exactly 1 short sentence." }
        else
                if isToxic then
                        msgs[#msgs+1] = { role = "system", content = TOXIC_PERSONA }
                else
                        msgs[#msgs+1] = { role = "system", content = buildPersona() }
                end
                if uidK then
                        local cx = getCrossMemoryContext(userMsg, uidK)
                        if cx then msgs[#msgs+1] = { role = "system", content = cx } end
                end
                if uidK and S.playerHistory[uidK] then
                        for _, h in ipairs(S.playerHistory[uidK]) do
                                msgs[#msgs+1] = h
                        end
                end
        end

        msgs[#msgs+1] = { role = "user", content = userMsg }

        local ok, res = pcall(function()
                return Http({
                        Url = API_URL, Method = "POST",
                        Headers = {
                                ["Content-Type"] = "application/json",
                                ["Authorization"] = "Bearer " .. S.key
                        },
                        Body = HttpService:JSONEncode({
                                model = S.currentModel, messages = msgs,
                                max_tokens = isObs and 35 or 100, temperature = 0.85
                        }),
                })
        end)

        S.thinking = false

        if not ok or not res then return nil, "NET" end
        if res.StatusCode == 429 then
                S.nextReq = tick() + 15
                -- Parse rate limit reset from headers
                pcall(function()
                        local headers = res.Headers or {}
                        if headers["x-ratelimit-reset-tokens"] then
                                S.tokenResetTime = tonumber(headers["x-ratelimit-reset-tokens"]) or 15
                        end
                        if headers["x-ratelimit-remaining-tokens"] then
                                S.remainingTokens = tonumber(headers["x-ratelimit-remaining-tokens"]) or 0
                        end
                end)
                return nil, "RATE"
        end
        S.nextReq = tick() + math.max(S.cooldown or 1, 1)
        if res.StatusCode == 401 then return nil, "KEY" end
        if res.StatusCode ~= 200 then return nil, "ERR" .. tostring(res.StatusCode) end

        -- Parse token usage from headers + body
        pcall(function()
                local headers = res.Headers or {}
                if headers["x-ratelimit-remaining-tokens"] then
                        S.remainingTokens = tonumber(headers["x-ratelimit-remaining-tokens"]) or S.remainingTokens
                end
                if headers["x-ratelimit-reset-tokens"] then
                        S.tokenResetTime = tonumber(headers["x-ratelimit-reset-tokens"]) or 0
                end
        end)

        local data
        local decodeOk = pcall(function() data = HttpService:JSONDecode(res.Body) end)
        if not decodeOk or not data then return nil, "DEC" end
        if not data.choices or not data.choices[1] then return nil, "NODATA" end

        local reply = data.choices[1].message and data.choices[1].message.content
        if not reply or type(reply) ~= "string" then return nil, "NOREPLY" end

        if data.usage then
                S.tokens = S.tokens + (tonumber(data.usage.total_tokens) or 0)
                S.totalTokensUsed = S.totalTokensUsed + (tonumber(data.usage.total_tokens) or 0)
        end

        if uidK and not isObs and not skipSave then
                addPlayerMem(uidK, "user", userMsg)
                addPlayerMem(uidK, "assistant", reply)
                saveMemory()
        end

        return reply, nil
end

-- ═══════════════════════════════════════════════════════════════
-- MESSAGE PERFORM
-- ═══════════════════════════════════════════════════════════════
local function perform(reply, name, uid, skipPrefix)
        if type(reply) ~= "string" then return end
        local msg = reply:gsub("^%s+", ""):gsub("%s+$", "")
        if not msg:match("%S") then return end
        if not skipPrefix and S.prefixName then
                local cn = name or ""
                if uid and S.playerNick[tostring(uid)] then
                        cn = S.playerNick[tostring(uid)]
                end
                if cn ~= "" then msg = "[" .. cn .. "] " .. msg end
        end
        sendChat(msg)
end

-- ═══════════════════════════════════════════════════════════════
-- WHITELIST CHECK
-- ═══════════════════════════════════════════════════════════════
local function isWhitelisted(plr)
        if not S.whitelistOn then return true end
        local uid = tostring(plr.UserId)
        local dn = plr.DisplayName:lower()
        local un = plr.Name:lower()
        for _, entry in ipairs(S.whitelist) do
                local e = tostring(entry):lower()
                if e == uid or e == dn or e == un then return true end
        end
        return false
end

-- ═══════════════════════════════════════════════════════════════
-- CHAT HANDLER
-- ═══════════════════════════════════════════════════════════════
local function handleChat(plr, msg)
        if not S.chatOn or not S.connected then return end
        if not plr or plr == LP then return end
        if not msg or type(msg) ~= "string" then return end

        local uid = tostring(plr.UserId)
        if S.blacklist[uid] then return end

        -- Whitelist check
        if not isWhitelisted(plr) then return end

        if S.range > 0 then
                if not HRP or not HRP.Parent then return end
                local pc = plr.Character
                if not pc then return end
                local ph = pc:FindFirstChild("HumanoidRootPart")
                if not ph then return end
                if (HRP.Position - ph.Position).Magnitude > S.range then return end
        end

        local now = tick()
        if now - S.spamT > 5 then S.globalN = 0; S.spamT = now end
        S.globalN = S.globalN + 1
        if S.globalN > 15 then S.nextReq = now + 5; return end
        if S.playerCD[plr] and (now - S.playerCD[plr]) < 2 then return end
        S.playerCD[plr] = now

        S.playerNames[uid] = plr.DisplayName
        if msg:match("[^\x00-\x7F]") then
                S.playerLang[uid] = "non-en"
        elseif not S.playerLang[uid] then
                S.playerLang[uid] = "en"
        end

        local nm = msg:match("[Cc]all me (.+)") or msg:match("เรียกฉันว่า%s*(.+)")
        if nm then
                local nick = (nm:match("^%s*(.-)%s*$") or ""):sub(1, 20)
                if nick ~= "" then
                        S.playerNick[uid] = nick
                        S.playerNames[uid] = nick
                        saveMemory()
                end
        end

        local sn = S.playerNick[uid] or plr.DisplayName
        local isToxic = S.toxicTargets[uid] == true

        task.spawn(function()
                if S.responseDelay > 0 then task.wait(S.responseDelay) end
                if not S.chatOn then return end
                local lang = S.playerLang[uid] == "non-en" and " [Same language]" or " [English]"
                local nick = S.playerNick[uid] and (" [Call them: " .. S.playerNick[uid] .. "]") or ""
                local reply = callGroq(msg .. lang .. nick, uid, sn, false, nil, isToxic)
                if reply then perform(reply, sn, uid) end
        end)
end

