local function fastTest(key)
    if not Http or not HttpSvc then return false end
    if type(key) ~= "string" or #key < 10 then return false end
    local ok, res = pcall(Http, {
        Url = API_URL, Method = "POST",
        Headers = { ["Content-Type"] = "application/json", ["Authorization"] = "Bearer " .. key },
        Body = HttpSvc:JSONEncode({ model = S.currentModel, messages = {{ role = "user", content = "ok" }}, max_tokens = 2 }),
    })
    return ok and res and res.StatusCode == 200
end

local function doConnect(key)
    if type(key) ~= "string" then return end
    key = key:gsub("%s+", "")
    if #key < 10 then safeProp(statusLbl, "Text", "● Invalid Key"); safeProp(statusLbl, "TextColor3", C.NO); return end
    S.key = key; S.thinking = false; S.nextReq = 0
    safeProp(statusLbl, "Text", "● Connecting..."); safeProp(statusLbl, "TextColor3", C.WN)
    task.spawn(function()
        if fastTest(key) then
            S.connected = true
            safeProp(statusLbl, "Text", "● Connected ✓"); safeProp(statusLbl, "TextColor3", C.OK)
            if pillDot then safeProp(pillDot, "BackgroundColor3", C.OK) end
            if writefile then pcall(function() writefile(KEY_FILE, key) end) end
            makeRing()
        else
            S.connected = false; S.key = ""
            safeProp(statusLbl, "Text", "● Connection Failed"); safeProp(statusLbl, "TextColor3", C.NO)
            if pillDot then safeProp(pillDot, "BackgroundColor3", C.NO) end
        end
    end)
end

