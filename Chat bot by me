        if #ringParts == 0 then return end
        ringAng = (ringAng + dt * 20) % 360
        if not HRP or not HRP.Parent then return end
        local r = S.range == 0 and 50 or S.range
        local y = HRP.Position.Y - HRP.Size.Y / 2 + .1
        for i, p in ipairs(ringParts) do
                if not p or not p.Parent then continue end
                local a = math.rad(((i - 1) / #ringParts) * 360 + ringAng)
                p.CFrame = CFrame.new(
                        HRP.Position.X + math.cos(a) * r, y,
                        HRP.Position.Z + math.sin(a) * r
                ) * CFrame.fromEulerAnglesYXZ(0, a + math.pi / 2, 0)
        end
end)

