local function getAction(plr)
        if not plr then return "?" end
        local c = plr.Character
        if not c then return "?" end
        local h = c:FindFirstChildOfClass("Humanoid")
        if not h then return "?" end
        local st = h:GetState()
        if st == Enum.HumanoidStateType.Running then return "running"
        elseif st == Enum.HumanoidStateType.Jumping then return "jumping"
        elseif st == Enum.HumanoidStateType.Freefall then return "falling"
        elseif st == Enum.HumanoidStateType.StrafingNoPhysics then return "dancing"
        elseif h.MoveDirection and h.MoveDirection.Magnitude > 0.1 then return "walking"
        else return "standing" end
end

local function getNearby()
        local list = {}
        if not HRP or not HRP.Parent then return list end
        for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character then
                        local ph = p.Character:FindFirstChild("HumanoidRootPart")
                        if ph then
                                local d = (HRP.Position - ph.Position).Magnitude
                                if d <= S.range then
                                        list[#list+1] = { plr = p, dist = d, act = getAction(p) }
                                end
                        end
                end
        end
        table.sort(list, function(a, b) return a.dist < b.dist end)
        return list
end

-- Unified greet prompt — same as popup Greet
local function makeGreetPrompt(name)
        return "[Greet " .. name .. " by saying their name '" .. name .. "' first naturally in the sentence, then add a casual friendly line. 1-2 short sentences only.]"
end

local function doObserve()
        unstick()
        if not S.talkOn or not S.connected or S.thinking then return end
        if tick() - S.lastObserve < S.observeInterval then return end

        local nearby = getNearby()
        if #nearby == 0 then return end

        if S.chatOn then
                local greetTarget = nil
                for _, d in ipairs(nearby) do
                        local uid = tostring(d.plr.UserId)
                        local nm = S.playerNick[uid] or d.plr.DisplayName
                        S.playerNames[uid] = d.plr.DisplayName
                        if S.blacklist[uid] then continue end
                        if not isWhitelisted(d.plr) then continue end
                        local hasHistory = S.playerHistory[uid] and #S.playerHistory[uid] > 0
                        if not hasHistory and not S.greetedPlayers[uid] then
                                greetTarget = { uid = uid, name = nm }
                                break
                        end
                end
                if greetTarget then
                        S.lastObserve = tick()
                        S.greetedPlayers[greetTarget.uid] = true
                        task.spawn(function()
                                local w = math.min(S.responseDelay, 1.5)
                                if w > 0 then task.wait(w) end
                                if not S.talkOn or not S.chatOn or not S.connected then return end
                                -- Same greet prompt as popup Greet button
                                local reply = callGroq(makeGreetPrompt(greetTarget.name), greetTarget.uid, greetTarget.name, false, true, false)
                                if reply then
                                        addPlayerMem(greetTarget.uid, "assistant", reply)
                                        saveMemory()
                                        perform(reply, greetTarget.name, greetTarget.uid, true)
                                end
                        end)
                        return
                end
        end

        local changed = false
        local lines = {}
        for _, d in ipairs(nearby) do
                local uid = tostring(d.plr.UserId)
                if S.blacklist[uid] then continue end
                if not isWhitelisted(d.plr) then continue end
                local nm = S.playerNick[uid] or d.plr.DisplayName
                local prev = S.lastActions[d.plr.Name]
                if not prev or prev ~= d.act then changed = true end
                S.lastActions[d.plr.Name] = d.act
                lines[#lines+1] = nm .. ": " .. d.act .. " (" .. math.floor(d.dist) .. "m)"
        end
        if #lines == 0 then return end
        if not changed and math.random(100) > 25 then return end
        S.lastObserve = tick()

        local memLines = {}
        local bestUid, bestCount = nil, 0
        for _, d in ipairs(nearby) do
                local uid = tostring(d.plr.UserId)
                if S.blacklist[uid] then continue end
                local hist = S.playerHistory[uid]
                if hist and #hist > bestCount then bestCount = #hist; bestUid = uid end
        end
        if bestUid and S.playerHistory[bestUid] then
                local hist = S.playerHistory[bestUid]
                local si = math.max(1, #hist - 5)
                for i = si, #hist do
                        local h = hist[i]
                        local nm = (h.role == "user")
                                and (S.playerNick[bestUid] or S.playerNames[bestUid] or "Player")
                                or "You"
                        memLines[#memLines+1] = nm .. ": " .. h.content
                end
        end

        local prompt
        if #memLines > 0 then
                prompt = "[Here is a past conversation from your memory:\n"
                        .. table.concat(memLines, "\n")
                        .. "\n\nBased on this past conversation, say something natural and casual that continues or references it. "
                        .. "Do NOT say 'I think'. Do NOT make up new topics. Speak like continuing an old conversation with a friend. "
                        .. "1 short sentence only.]"
        else
                local ctx = "Nearby:\n" .. table.concat(lines, "\n")
                if changed then ctx = ctx .. "\n[Something changed, react naturally. 1 short sentence.]" end
                prompt = ctx
        end

        task.spawn(function()
                local w = math.min(S.responseDelay, 1.5)
                if w > 0 then task.wait(w) end
                if not S.talkOn or not S.connected then return end
                local reply = callGroq(prompt, nil, nil, #memLines == 0)
                if reply then
                        local m = reply:gsub("^%s+", ""):gsub("%s+$", "")
                        if m:match("%S") then sendChat(m) end
                end
        end)
end

Players.PlayerRemoving:Connect(function(p)
        if not p then return end
        S.lastActions[p.Name] = nil
        local uid = tostring(p.UserId)
        S.greetedPlayers[uid] = nil
        S.toxicTargets[uid] = nil
end)

task.spawn(function()
