    rp.FilterDescendantsInstances = LP.Character and {LP.Character} or {}
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
    local stillOn = result and result.Instance and holdTarget and holdTarget.Character
        and result.Instance:IsDescendantOf(holdTarget.Character)
    if not stillOn then cancelHold(); return end
    local progress = math.clamp((tick()-holdStartTime) / math.max(S.holdDuration,.1), 0, 1)
    local maxFill = IND_SIZE - 8; local fillSz = progress * maxFill
