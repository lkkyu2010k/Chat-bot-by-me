local function makePage(name)
    local pg = Instance.new("ScrollingFrame", ContentBG)
    pg.Name = "Page_" .. name
    pg.Size = UDim2.new(1, 0, 1, -(HDR_H + 6))
    pg.Position = UDim2.fromOffset(0, HDR_H + 6)
    pg.BackgroundTransparency = 1; pg.ScrollBarThickness = 3
    pg.ScrollBarImageColor3 = C.BD; pg.ScrollBarImageTransparency = 0.3
    pg.AutomaticCanvasSize = Enum.AutomaticSize.Y; pg.CanvasSize = UDim2.new()
    pg.ZIndex = 13; pg.Visible = false; pg.ClipsDescendants = true
    pg.ElasticBehavior = Enum.ElasticBehavior.Never
    local ll = Instance.new("UIListLayout", pg)
    ll.Padding = UDim.new(0, 5); ll.SortOrder = Enum.SortOrder.LayoutOrder
    local pad = Instance.new("UIPadding", pg)
    pad.PaddingLeft = UDim.new(0, 7); pad.PaddingRight = UDim.new(0, 7)
    pad.PaddingTop = UDim.new(0, 5); pad.PaddingBottom = UDim.new(0, 8)
    tabPages[name] = pg; return pg
end

local function setWinHeight(tabName)
    if not Camera then return end
    local targetH = math.clamp(TAB_WIN_H[tabName] or 300, MIN_H, math.floor(Camera.ViewportSize.Y * 0.92))
    gH = targetH
    pcall(function()
        Tw(Main, .28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {Size = UDim2.fromOffset(gW, gH)})
    end)
end

local function switchTab(name)
    if activeTab == name then return end
    if activeTab then
        local oldPg = tabPages[activeTab]
        if oldPg then
            pcall(function()
                Tw(oldPg, .06, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {BackgroundTransparency = 1})
            end)
            task.delay(.07, function()
                pcall(function()
                    oldPg.Visible = false
                    oldPg.BackgroundTransparency = 1
                end)
            end)
        end
        if tabBtns[activeTab] then
            pcall(function() tabBtns[activeTab](false) end)
        end
    end
    activeTab = name
    local newPg = tabPages[name]
    if newPg then
        newPg.Visible = true
        newPg.BackgroundTransparency = .1
        pcall(function()
            Tw(newPg, .12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {BackgroundTransparency = 1})
        end)
        newPg.CanvasPosition = Vector2.new(0, 0)
    end
    if tabBtns[name] then
        pcall(function() tabBtns[name](true) end)
    end
    contentTitle.Text = TAB_NAMES[name] or name
    setWinHeight(name)
end

local function makeTab(icon, label, name, order)
    local btn = Instance.new("TextButton", TabBar)
    btn.AutomaticSize = Enum.AutomaticSize.X
    btn.Size = UDim2.new(0, 0, 0, 28)
    btn.BackgroundTransparency = 1; btn.BackgroundColor3 = C.CD
    btn.BorderSizePixel = 0; btn.Text = ""; btn.ZIndex = 13; btn.LayoutOrder = order
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)
    local bPad = Instance.new("UIPadding", btn)
    bPad.PaddingLeft = UDim.new(0, 7); bPad.PaddingRight = UDim.new(0, 7)
    local iconL = L(btn, icon, UDim2.new(0, 14, 1, 0), nil, 12, BF, C.T2, Enum.TextXAlignment.Center, 14)
    local nameL = L(btn, label, UDim2.new(0, 0, 1, 0), UDim2.fromOffset(17, 0), 9, RF, C.T2, Enum.TextXAlignment.Left, 14)
    nameL.AutomaticSize = Enum.AutomaticSize.X
    local accent = Instance.new("Frame", btn)
    accent.Size = UDim2.new(0.6, 0, 0, 2)
    accent.Position = UDim2.new(0.2, 0, 1, -2)
    accent.BackgroundColor3 = C.WN; accent.BorderSizePixel = 0
    accent.ZIndex = 14; accent.Visible = false
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 2)
    local hBg = Instance.new("Frame", btn)
    hBg.Size = UDim2.new(1, 0, 1, 0); hBg.BackgroundTransparency = 1
    hBg.BackgroundColor3 = C.CD; hBg.BorderSizePixel = 0; hBg.ZIndex = -1
    Instance.new("UICorner", hBg).CornerRadius = UDim.new(0, 7)
    btn.MouseEnter:Connect(function()
        if activeTab ~= name then
            pcall(function() Tw(hBg, .1, nil, nil, {BackgroundTransparency = .4}) end)
        end
    end)
    btn.MouseLeave:Connect(function()
        pcall(function() Tw(hBg, .1, nil, nil, {BackgroundTransparency = 1}) end)
    end)
    tabBtns[name] = function(active)
        btn.BackgroundTransparency = active and 0 or 1
        accent.Visible = active
        iconL.TextColor3 = active and C.T1 or C.T2
        nameL.TextColor3 = active and C.T1 or C.T2
        nameL.Font = active and BF or RF
        hBg.BackgroundTransparency = 1
    end
    btn.MouseButton1Click:Connect(function() switchTab(name) end)
end

