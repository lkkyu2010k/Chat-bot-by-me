-- Apply theme function (needs sg)
applyTheme = function()
    local newT = darkModeOn and THEMES.light or THEMES.dark
    local oldT = darkModeOn and THEMES.dark  or THEMES.light
    local cmap = {}
    for k, oc in pairs(oldT) do if newT[k] then cmap[colorKey(oc)] = newT[k] end end
    local function walk(inst)
        pcall(function()
            if inst:IsA("GuiObject") then
                local m = cmap[colorKey(inst.BackgroundColor3)]
                if m and TweenSvc then TweenSvc:Create(inst, THEME_TI, {BackgroundColor3 = m}):Play() end
            end
            if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
                local m = cmap[colorKey(inst.TextColor3)]
                if m and TweenSvc then TweenSvc:Create(inst, THEME_TI, {TextColor3 = m}):Play() end
            end
            if inst:IsA("UIStroke") then
                local m = cmap[colorKey(inst.Color)]
                if m and TweenSvc then TweenSvc:Create(inst, THEME_TI, {Color = m}):Play() end
            end
        end)
        for _, ch in ipairs(inst:GetChildren()) do walk(ch) end
    end
    walk(sg)
    for k, v in pairs(newT) do C[k] = v end
    darkModeOn = not darkModeOn
end

