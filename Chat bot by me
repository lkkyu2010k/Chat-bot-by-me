    if not uid then return end
    if not S.playerHistory[uid] then S.playerHistory[uid] = {} end
    table.insert(S.playerHistory[uid], { role = role, content = content })
    while #S.playerHistory[uid] > S.maxPlayerHist * 2 do
        table.remove(S.playerHistory[uid], 1)
    end
end

