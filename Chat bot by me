-- [NEW] Talk button — continue current topic
btnTalk.MouseButton1Click:Connect(function()
    local target = getPopupTarget()
    closeRadialPopup()
    if not target or not S.connected then return end
    local uid = tostring(target.UserId)
    local nm = S.playerNick[uid] or target.DisplayName
    local hist = S.playerHistory[uid]

    local prompt
    if hist and #hist > 0 then
        local lines = {}
        local si = math.max(1, #hist - 4)
        for i = si, #hist do
            lines[#lines+1] = (hist[i].role == "user" and nm or "You") .. ": " .. hist[i].content
        end
        prompt = "[Based on this recent conversation with " .. nm .. ":\n"
            .. table.concat(lines, "\n")
            .. "\n\nContinue talking naturally about the same topic. Keep it short and casual. Do NOT say their name.]"
    else
        prompt = "[Start a fun casual conversation with " .. nm .. ". Pick any interesting topic. 1-2 short sentences. Do NOT say their name.]"
    end

    task.spawn(function()
        if S.responseDelay > 0 then task.wait(S.responseDelay) end
        if not S.connected then return end
        local reply = callGroq(prompt, uid, nm, false, true, false)
        if reply then
            addPlayerMem(uid, "assistant", reply)
            saveMemory()
            perform(reply, nm, uid, true)
        end
    end)
end)

