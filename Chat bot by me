-- forward-declare showRadialPopup
local showRadialPopup

local function completeHold()
    local target = holdTarget
    holdActive = false; holdTarget = nil
    if holdIndicator then safeProp(holdIndicator,"Visible",false) end
    if holdFill then safeProp(holdFill,"Size",UDim2.fromOffset(0,0)) end
    if holdPctLbl then safeProp(holdPctLbl,"Text","") end
    if target and target.Character and target.Parent then
        local head = target.Character:FindFirstChild("Head")
        local sp
        if head then
            local p, _ = Camera:WorldToScreenPoint(head.Position); sp = Vector2.new(p.X, p.Y)
        else
            local root = target.Character:FindFirstChild("HumanoidRootPart")
            if root then local p, _ = Camera:WorldToScreenPoint(root.Position + Vector3.new(0,3,0)); sp = Vector2.new(p.X, p.Y) end
        end
        if sp and showRadialPopup then showRadialPopup(sp, target) end
    end
end

UIS.InputBegan:Connect(function(inp, gpe)
    if gpe or holdActive or addModeActive then return end
    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 and inp.UserInputType ~= Enum.UserInputType.Touch then return end
    local ok, guisAtPos = pcall(function() if GuiSvc then return GuiSvc:GetGuiObjectsAtPosition(inp.Position.X, inp.Position.Y) end end)
    if ok and guisAtPos and #guisAtPos > 0 then return end
    local ray = Camera:ScreenPointToRay(inp.Position.X, inp.Position.Y)
    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = LP.Character and {LP.Character} or {}
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
    if result and result.Instance then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character and result.Instance:IsDescendantOf(p.Character) then
                holdTarget = p; holdStartTime = tick(); holdActive = true
                if holdIndicator then
                    safeProp(holdIndicator,"Position",UDim2.fromOffset(inp.Position.X-IND_SIZE/2, inp.Position.Y-IND_SIZE/2))
                    safeProp(holdIndicator,"Visible",true)
                end
                if holdFill then safeProp(holdFill,"Size",UDim2.fromOffset(0,0)) end
                if holdPctLbl then safeProp(holdPctLbl,"Text","0%") end
                break
            end
        end
    end
end)
