                    .. "Be casual and friendly. Do NOT say their name. 1-2 short sentences only.]"
            else
                prompt = "[Start a short casual conversation with " .. nm .. " without saying their name. "
                    .. "Pick any light topic — game, weather, random thought. 1-2 sentences only.]"
            end
            local isToxic = S.toxicTargets[uid] == true
            local reply = callGroq(prompt, uid, nm, false, false, isToxic)
            if reply then perform(reply,nm,uid,true) end
