local function setWinH(tabName)
    if not Camera then return end
    local targetH = math.clamp(TAB_WIN_H[tabName] or 300, MIN_H, math.floor(Camera.ViewportSize.Y * 0.92))
    gH = targetH
    Tw(Main, .28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { Size = UDim2.fromOffset(gW, gH) })
end

local function switchTab(name)
    if activeTab == name then return end
    if activeTab then
        local oldPg = tabPages[activeTab]
        if oldPg and oldPg.Visible ~= nil then
            Tw(oldPg, .06, nil, nil, { BackgroundTransparency = 1 })
            task.delay(.07, function() pcall(function() oldPg.Visible = false end) end)
        end
        if tabBtns[activeTab] then pcall(function() tabBtns[activeTab](false) end) end
    end
    activeTab = name
    local newPg = tabPages[name]
    if newPg and newPg.Visible ~= nil then
        newPg.Visible = true
        Tw(newPg, .12, nil, nil, { BackgroundTransparency = 1 })
        safeProp(newPg, "CanvasPosition", Vector2.new(0, 0))
    end
    if tabBtns[name] then pcall(function() tabBtns[name](true) end) end
    safeProp(contentTitle, "Text", TAB_NAMES[name] or name)
    setWinH(name)
end

