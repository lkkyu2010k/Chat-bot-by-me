-- Cancel Toxic
btnCancelToxic.MouseButton1Click:Connect(function()
    local target = getPopupTarget()
    closeRadialPopup()
    if not target then return end
    local uid = tostring(target.UserId)
    local nm = S.playerNick[uid] or target.DisplayName

    if S.toxicTargets[uid] then
        -- 1. Turn off toxic immediately
        S.toxicTargets[uid] = nil

        -- 2. Clear history
        clearPlayerHistory(uid)

        pcall(function()
            if StarterGui then
                StarterGui:SetCore("SendNotification", {
                    Title = "✅ Toxic Mode OFF",
                    Text = "No longer toxic to: " .. nm, Duration = 3
                })
            end
        end)

        -- 3. Send apology
        if S.connected then
            task.spawn(function()
                if S.responseDelay > 0 then task.wait(S.responseDelay) end
                if not S.connected then return end
                local prompt = "[You were just being toxic to " .. nm .. " but now you've calmed down and feel genuinely sorry. Apologize sincerely to them. You MUST say their name '" .. nm .. "' first. Be genuinely remorseful and friendly. 1-2 short sentences. Do NOT use ALL CAPS. Use normal sentence case only.]"
                local reply = callGroq(prompt, uid, nm, false, true, false)
                if reply then
                    addPlayerMem(uid, "assistant", reply)
                    saveMemory()
                    perform(reply, nm, uid, true)
                end
            end)
        end
    else
        pcall(function()
            if StarterGui then
                StarterGui:SetCore("SendNotification", {
                    Title = "ℹ️ Info",
                    Text = nm .. " is not in toxic mode", Duration = 2
                })
            end
        end)
    end
end)

