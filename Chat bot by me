-- TAB SYSTEM
-- ═══════════════════════════════════════════════════════════════
local tabPages, tabBtns, activeTab = {}, {}, nil

local TAB_DATA = {
        {icon = "🔑", name = "api",       label = "API Key"},
        {icon = "💬", name = "controls",  label = "Controls"},
        {icon = "⚙️", name = "settings",  label = "Settings"},
        {icon = "🎭", name = "mood",      label = "Mood"},
        {icon = "✏️", name = "persona",   label = "Persona"},
        {icon = "💾", name = "memory",    label = "Memory"},
        {icon = "⛔", name = "blacklist", label = "Block"},
        {icon = "✅", name = "whitelist", label = "Whitelist"},
        {icon = "🎨", name = "theme",     label = "Theme"},
}

local function makePage(name)
        local pg = Instance.new("ScrollingFrame", ContentBG)
        pg.Name = "Page_" .. name
        pg.Size = UDim2.new(1, 0, 1, -(HDR_H + 8))
        pg.Position = UDim2.fromOffset(0, HDR_H + 8)
        pg.BackgroundTransparency = 1; pg.ScrollBarThickness = 3
        pg.ScrollBarImageColor3 = C.BD; pg.ScrollBarImageTransparency = 0.3
        pg.AutomaticCanvasSize = Enum.AutomaticSize.Y; pg.CanvasSize = UDim2.new()
        pg.ZIndex = 13; pg.Visible = false; pg.ClipsDescendants = true
        pg.ElasticBehavior = Enum.ElasticBehavior.Never
        local ll = Instance.new("UIListLayout", pg)
        ll.Padding = UDim.new(0, 6); ll.SortOrder = Enum.SortOrder.LayoutOrder
        local pad = Instance.new("UIPadding", pg)
        pad.PaddingLeft = UDim.new(0, 8); pad.PaddingRight = UDim.new(0, 8)
        pad.PaddingTop = UDim.new(0, 6); pad.PaddingBottom = UDim.new(0, 10)
        tabPages[name] = pg; return pg
end

local function switchTab(name)
        if activeTab == name then return end
        -- Slide out old page
        if activeTab then
                local oldPg = tabPages[activeTab]
                if oldPg then
                        pcall(function()
                                oldPg.Visible = true
                                Tw(oldPg, .2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
                                        Position = UDim2.fromOffset(-40, HDR_H + 8),
                                        BackgroundTransparency = 1
                                })
                        end)
                        task.delay(.21, function() pcall(function()
                                oldPg.Visible = false
                                oldPg.Position = UDim2.fromOffset(0, HDR_H + 8)
                                oldPg.BackgroundTransparency = 1
                        end) end)
                end
                if tabBtns[activeTab] then pcall(function() tabBtns[activeTab](false) end) end
        end
        activeTab = name
        local newPg = tabPages[name]
        if newPg then
                newPg.Visible = true
                newPg.Position = UDim2.fromOffset(40, HDR_H + 8)
                newPg.BackgroundTransparency = .3
                newPg.CanvasPosition = Vector2.new(0, 0)
                pcall(function()
                        Tw(newPg, .2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
                                Position = UDim2.fromOffset(0, HDR_H + 8),
                                BackgroundTransparency = 1
                        })
                end)
        end
        if tabBtns[name] then pcall(function() tabBtns[name](true) end) end
        -- Find label
        for _, td in ipairs(TAB_DATA) do
                if td.name == name then contentTitle.Text = td.label; break end
        end
end

for idx, td in ipairs(TAB_DATA) do
        local btn = Instance.new("TextButton", TabBar)
        btn.Size = UDim2.new(0, 90, 1, -4)
        btn.BackgroundColor3 = C.CD; btn.BorderSizePixel = 0
        btn.Text = td.icon .. " " .. td.label; btn.Font = BF; btn.TextSize = 9
        btn.TextColor3 = C.T2; btn.AutoButtonColor = false
        btn.ZIndex = 13; btn.LayoutOrder = idx
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

        -- Bottom indicator for active tab
        local selInd = Instance.new("Frame", btn)
        selInd.Size = UDim2.new(0.6, 0, 0, 3)
        selInd.Position = UDim2.new(0.2, 0, 1, -3)
        selInd.BackgroundColor3 = C.AC; selInd.BorderSizePixel = 0
        selInd.ZIndex = 14; selInd.Visible = false
        Instance.new("UICorner", selInd).CornerRadius = UDim.new(0, 2)

        addHover(btn)

        tabBtns[td.name] = function(active)
                selInd.Visible = active
                btn.TextColor3 = active and C.AC or C.T2
                pcall(function() Tw(btn, .12, nil, nil, {BackgroundColor3 = active and C.AREA or C.CD}) end)
        end
        btn.MouseButton1Click:Connect(function() switchTab(td.name) end)
end

