holdPctLbl.TextXAlignment = Enum.TextXAlignment.Center

local holdActive, holdStartTime, holdTarget = false, 0, nil

local function cancelHold()
        holdActive = false; holdTarget = nil; holdIndicator.Visible = false
        holdFill.Size = UDim2.fromOffset(0, 0); holdPctLbl.Text = ""
end

local function completeHold()
        local target = holdTarget
        holdActive = false; holdTarget = nil; holdIndicator.Visible = false
        holdFill.Size = UDim2.fromOffset(0, 0); holdPctLbl.Text = ""
        if target and target.Character and target.Parent then
                local head = target.Character:FindFirstChild("Head")
                local screenPos
                if head then
                        local sp, _ = Camera:WorldToScreenPoint(head.Position)
                        screenPos = Vector2.new(sp.X, sp.Y)
                else
                        local rootPart = target.Character:FindFirstChild("HumanoidRootPart")
                        if rootPart then
                                local sp, _ = Camera:WorldToScreenPoint(rootPart.Position + Vector3.new(0, 3, 0))
                                screenPos = Vector2.new(sp.X, sp.Y)
                        end
                end
                if screenPos then showRadialPopup(screenPos, target) end
        end
end

UIS.InputBegan:Connect(function(inp, gpe)
        if gpe or holdActive or addModeActive then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        local ok, guisAtPos = pcall(function()
                return GuiService and GuiService:GetGuiObjectsAtPosition(inp.Position.X, inp.Position.Y) or nil
        end)
        if ok and guisAtPos and #guisAtPos > 0 then return end
        local ray = Camera:ScreenPointToRay(inp.Position.X, inp.Position.Y)
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.FilterDescendantsInstances = LP.Character and {LP.Character} or {}
        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
        if result and result.Instance then
                for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= LP and p.Character and result.Instance:IsDescendantOf(p.Character) then
                                holdTarget = p; holdStartTime = tick(); holdActive = true
                                holdIndicator.Position = UDim2.fromOffset(inp.Position.X - IND_SIZE / 2, inp.Position.Y - IND_SIZE / 2)
                                holdIndicator.Visible = true; holdFill.Size = UDim2.fromOffset(0, 0)
                                holdPctLbl.Text = "0%"; break
                        end
                end
        end
end)

UIS.InputEnded:Connect(function(inp)
        if not holdActive then return end
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                cancelHold()
        end
end)

RunService.Heartbeat:Connect(function(dt)
        if not holdActive then return end
        local mousePos = UIS:GetMouseLocation()
        local ray = Camera:ScreenPointToRay(mousePos.X, mousePos.Y)
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.FilterDescendantsInstances = LP.Character and {LP.Character} or {}
        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
        local stillOnTarget = false
        if result and result.Instance and holdTarget and holdTarget.Character then
                stillOnTarget = result.Instance:IsDescendantOf(holdTarget.Character)
        end
        if not stillOnTarget then cancelHold(); return end
        local elapsed = tick() - holdStartTime
        local progress = math.clamp(elapsed / math.max(S.holdDuration, 0.1), 0, 1)
        local fillMax = IND_SIZE - 8
        holdFill.Size = UDim2.fromOffset(progress * fillMax, progress * fillMax)
        holdFill.BackgroundTransparency = 0.5 - progress * 0.3
        holdIndicator.Position = UDim2.fromOffset(mousePos.X - IND_SIZE / 2, mousePos.Y - IND_SIZE / 2)
        holdPctLbl.Position = UDim2.fromOffset(mousePos.X - IND_SIZE / 2, mousePos.Y + IND_SIZE / 2 + 3)
        holdPctLbl.Text = math.floor(progress * 100) .. "%"
        if progress >= 1 then completeHold() end
end)

