local function updateRateLimitUI() -- [NEW]
    local rl = S.rateLimit
    local tStr = rl.remainingTokens and tostring(rl.remainingTokens) or "--"
    local rStr = rl.remainingRequests and tostring(rl.remainingRequests) or "--"
    tokStatusLbl.Text = "Tokens: " .. tStr .. " | Requests: " .. rStr

    local now = tick()
    local parts = {}
    if rl.resetTokensEpoch and rl.resetTokensEpoch > now then
        parts[#parts+1] = "Tok reset " .. math.ceil(rl.resetTokensEpoch - now) .. "s"
    end
    if rl.resetRequestsEpoch and rl.resetRequestsEpoch > now then
        parts[#parts+1] = "Req reset " .. math.ceil(rl.resetRequestsEpoch - now) .. "s"
    end
    tokResetLbl.Text = #parts > 0 and table.concat(parts, " | ") or "Limits refreshed"

    if rl.remainingTokens and rl.remainingTokens < 500 then
        tokStatusLbl.TextColor3 = C.NO
    elseif rl.remainingTokens and rl.remainingTokens < 1500 then
        tokStatusLbl.TextColor3 = C.WN
    else
        tokStatusLbl.TextColor3 = C.T1
    end
end

