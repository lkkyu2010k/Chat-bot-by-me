local function mkCard(pg, h, order)
        local c = F(pg, UDim2.new(1, -3, 0, h), nil, C.CARD, 10, 14)
        c.LayoutOrder = order; return c
end

local function mkLabel(card, text, y)
        return L(card, text, UDim2.new(1, -12, 0, 14), UDim2.fromOffset(8, y), 8, BF, C.T2, Enum.TextXAlignment.Left, 15)
end

local function mkToggle(card, y, label, key)
        local row = Instance.new("Frame", card)
        row.Size = UDim2.new(1, -12, 0, 30); row.Position = UDim2.fromOffset(8, y)
        row.BackgroundTransparency = 1; row.ZIndex = 15
        L(row, label, UDim2.new(1, -54, 1, 0), nil, 10, RF, C.T1, Enum.TextXAlignment.Left, 15)
        local on = S[key]
        local tb = B(row, on and "ON" or "OFF", UDim2.fromOffset(48, 24), UDim2.new(1, -48, .5, -12),
                on and C.OK or C.CD, on and C.WIN or C.T2, 9, 16)
        addHover(tb)
        tb.MouseButton1Click:Connect(function()
                S[key] = not S[key]
                tb.Text = S[key] and "ON" or "OFF"
                tb.BackgroundColor3 = S[key] and C.OK or C.CD
                tb.TextColor3 = S[key] and C.WIN or C.T2
                saveSettings()
        end)
end

local function mkInput(card, y, label, key, minV, maxV, cb)
        local row = Instance.new("Frame", card)
        row.Size = UDim2.new(1, -12, 0, 30); row.Position = UDim2.fromOffset(8, y)
        row.BackgroundTransparency = 1; row.ZIndex = 15
        L(row, label, UDim2.new(1, -64, 1, 0), nil, 10, RF, C.T1, Enum.TextXAlignment.Left, 15)
        local box = Instance.new("TextBox", row)
        box.Size = UDim2.fromOffset(56, 24); box.Position = UDim2.new(1, -56, .5, -12)
        box.BackgroundColor3 = C.CD; box.BorderSizePixel = 0
        box.Text = tostring(S[key]); box.TextColor3 = C.T1
        box.PlaceholderColor3 = C.T2; box.Font = BF; box.TextSize = 10
        box.ZIndex = 16; box.ClearTextOnFocus = false
        Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
        box.FocusLost:Connect(function()
                local n = tonumber(box.Text)
                if n then
                        n = math.clamp(n, minV or 0, maxV or 9999)
                        S[key] = n; saveSettings(); if cb then cb(n) end; box.Text = tostring(n)
                else box.Text = tostring(S[key]) end
        end)
end

local function mkSlider(card, y, label, key)
        local row = Instance.new("Frame", card)
        row.Size = UDim2.new(1, -12, 0, 28); row.Position = UDim2.fromOffset(8, y)
        row.BackgroundTransparency = 1; row.ZIndex = 15
        L(row, label, UDim2.new(.28, 0, 1, 0), nil, 10, BF, C.T1, Enum.TextXAlignment.Left, 15)
        local vl = L(row, tostring(S.traits[key]), UDim2.new(.1, 0, 1, 0), UDim2.new(.28, 0, 0, 0), 10, BF, C.AC, Enum.TextXAlignment.Center, 15)
        local track = F(row, UDim2.new(.54, 0, 0, 4), UDim2.new(.4, 0, .5, -2), C.CD, 2, 15)
        local fill = F(track, UDim2.new(S.traits[key] / 10, 0, 1, 0), UDim2.new(), C.AC, 2, 16)
        local dr = false
        local function upd(i)
                local rx = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local v = math.floor(rx * 10)
                S.traits[key] = v; vl.Text = tostring(v)
                fill.Size = UDim2.new(rx, 0, 1, 0); saveSettings()
        end
        track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = true; upd(i) end
        end)
        UIS.InputChanged:Connect(function(i)
                if dr and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then upd(i) end
        end)
        UIS.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = false end
        end)
end

