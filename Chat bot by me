-- CHAT SEND
-- ═══════════════════════════════════════════════════════════════
local function sendRaw(text)
        if type(text) ~= "string" or text == "" then return false end
        local ok = false
        if TextChat and TextChat.ChatVersion == Enum.ChatVersion.TextChatService then
                pcall(function()
                        local chs = TextChat:FindFirstChild("TextChannels")
                        if chs then
                                local ch = chs:FindFirstChild("RBXGeneral") or chs:FindFirstChild("General")
                                if ch and ch.SendAsync then ch:SendAsync(text); ok = true end
                        end
                end)
        end
        if not ok and RepStorage then
                pcall(function()
                        local ev = RepStorage:FindFirstChild("DefaultChatSystemChatEvents")
                        if ev then
                                local say = ev:FindFirstChild("SayMessageRequest")
                                if say and say.FireServer then say:FireServer(text, "All"); ok = true end
                        end
                end)
        end
        return ok
end

local function sendChat(text)
        if not text or type(text) ~= "string" then return end
        text = text:match("^%s*(.-)%s*$") or ""
        if text:gsub("%s+", "") == "" then return end
        if #text <= CHAT_LIMIT then sendRaw(text); return end
        local chunks, rem = {}, text
        while #rem > 0 do
                if #rem <= CHAT_LIMIT then chunks[#chunks+1] = rem; break end
                local cut = CHAT_LIMIT
                for j = CHAT_LIMIT, math.max(CHAT_LIMIT - 30, 1), -1 do
                        if rem:sub(j, j) == " " then cut = j - 1; break end
                end
                chunks[#chunks+1] = rem:sub(1, cut)
                rem = (rem:sub(cut + 1):match("^%s*(.-)%s*$") or "")
        end
        task.spawn(function()
                for i, c in ipairs(chunks) do
                        sendRaw(c .. " " .. i .. "/" .. #chunks)
                        if i < #chunks then task.wait(0.5) end
                end
        end)
end

