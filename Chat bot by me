local function mkSlider(card, y, label, key)
    local row = safeNew("Frame")
    if not row then return end
    safeProp(row, "Size", UDim2.new(1, -12, 0, 26))
    safeProp(row, "Position", UDim2.fromOffset(6, y))
    safeProp(row, "BackgroundTransparency", 1)
    safeProp(row, "ZIndex", 15)
    safeProp(row, "Parent", card)
    L(row, label, UDim2.new(.28, 0, 1, 0), nil, 10, BF, C.T1, Enum.TextXAlignment.Left, 15)
    local vl = L(row, tostring(S.traits[key]), UDim2.new(.1, 0, 1, 0), UDim2.new(.28, 0, 0, 0), 10, BF, C.AC, Enum.TextXAlignment.Center, 15)
    local track = F(row, UDim2.new(.54, 0, 0, 4), UDim2.new(.4, 0, .5, -2), C.CD, 2, 15)
    local fill  = F(track, UDim2.new(S.traits[key] / 10, 0, 1, 0), UDim2.new(), C.AC, 2, 16)
    local dr = false
    local function upd(i)
        local rx = math.clamp((i.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
        local v = math.floor(rx * 10)
        S.traits[key] = v
        safeProp(vl, "Text", tostring(v))
        safeProp(fill, "Size", UDim2.new(rx, 0, 1, 0))
        saveSettings()
    end
    pcall(function()
        track.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dr = true; upd(i)
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if dr and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then upd(i) end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dr = false end
        end)
    end)
end

