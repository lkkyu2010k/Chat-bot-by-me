btnChat.MouseButton1Click:Connect(function()
        local target = getPopupTarget()
        closeRadialPopup()
        if not target or not S.connected then return end
        local uid = tostring(target.UserId)
        local nm = S.playerNick[uid] or target.DisplayName
        S.playerNames[uid] = target.DisplayName

        task.spawn(function()
                if S.responseDelay > 0 then task.wait(S.responseDelay) end
                if not S.connected then return end

                -- Check if there's existing history with this player
                local hist = S.playerHistory[uid]
                local prompt
                if hist and #hist > 0 then
                        -- Continue the current topic
                        prompt = "[Continue the conversation naturally with " .. nm .. ". Reference your last exchange and say something related. Keep it casual and short, like talking to an old friend. 1-2 short sentences. Do NOT say their name.]"
                        local reply = callGroq(prompt, uid, nm, false, nil, S.toxicTargets[uid] == true)
                        if reply then perform(reply, nm, uid) end
                else
                        -- No history, just greet them
                        local reply = callGroq(makeGreetPrompt(nm), uid, nm, false, true, false)
                        if reply then
                                addPlayerMem(uid, "assistant", reply); saveMemory()
                                perform(reply, nm, uid, true)
                        end
                end
        end)
end)

