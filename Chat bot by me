local function closeRadialPopup()
    if iPopup then safeProp(iPopup,"Visible",false) end
    if iCloseZone then safeProp(iCloseZone,"Visible",false) end
    iPopupVisible = false
    if targetNameLbl then safeProp(targetNameLbl,"Text","") end
end

showRadialPopup = function(screenPos, targetPlayer)
    iPopupVisible = true
    if targetNameLbl then safeProp(targetNameLbl,"Text",targetPlayer.DisplayName) end
    local vp = Camera.ViewportSize
    local px = math.clamp(screenPos.X - CENTER, 4, vp.X - POP_SIZE - 4)
    local py = math.clamp(screenPos.Y - CENTER - 40, 4, vp.Y - POP_SIZE - 4)
    if iPopup then
        safeProp(iPopup,"Position",UDim2.fromOffset(px,py))
        safeProp(iPopup,"Visible",true)
    end
    if iCloseZone then safeProp(iCloseZone,"Visible",true) end

    -- Reset sizes to 0 for animation
    local function rst(btn, cx, cy)
        if not btn or not btn.Size then return end
        safeProp(btn,"Size",UDim2.fromOffset(0,0))
        safeProp(btn,"Position",UDim2.fromOffset(cx,cy))
    end
    if mainCircle then safeProp(mainCircle,"Size",UDim2.fromOffset(0,0)); safeProp(mainCircle,"Position",UDim2.fromOffset(CENTER,CENTER)) end
    rst(btnGreet,       CENTER,        CENTER-OFFSET)
    rst(btnBye,         CENTER,        CENTER+OFFSET)
    rst(btnToxic,       CENTER+OFFSET, CENTER)
    rst(btnCancelToxic, CENTER-OFFSET, CENTER)
    rst(btnChat,        CENTER+DIAG,   CENTER-DIAG)

    -- Animate in
    Tw(mainCircle, .22, Enum.EasingStyle.Back, Enum.EasingDirection.Out, { Size=UDim2.fromOffset(MAIN_R*2,MAIN_R*2), Position=UDim2.fromOffset(CENTER-MAIN_R,CENTER-MAIN_R) })
    local function anim(btn, tx, ty)
        if not btn or not btn.Size then return end
        Tw(btn, .28, Enum.EasingStyle.Back, Enum.EasingDirection.Out, { Size=UDim2.fromOffset(SMALL_R*2,SMALL_R*2), Position=UDim2.fromOffset(tx,ty) })
    end
    anim(btnGreet,       CENTER-SMALL_R, CENTER-OFFSET-SMALL_R)
    anim(btnBye,         CENTER-SMALL_R, CENTER+OFFSET-SMALL_R)
    anim(btnToxic,       CENTER+OFFSET-SMALL_R, CENTER-SMALL_R)
    anim(btnCancelToxic, CENTER-OFFSET-SMALL_R, CENTER-SMALL_R)
    anim(btnChat,        CENTER+DIAG-SMALL_R,   CENTER-DIAG-SMALL_R)
end

